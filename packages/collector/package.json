{
  "name": "@usecalibrate/collector",
  "version": "0.1.0",
  "description": "Self-hostable Calibrate collector: ingest, persistence, and a dashboard. Runs anywhere Node runs.",
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "bin": {
    "calibrate-collector": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {
    "@usecalibrate/contract": "0.1.0",
    "better-sqlite3": "^11.10.0",
    "express": "^4.21.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.10"
  },
  "engines": {
    "node": ">=20"
  }
}
